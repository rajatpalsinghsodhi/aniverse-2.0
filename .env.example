# Gemini (existing)
GEMINI_API_KEY=

# Auth — local dev: optional (defaults to insecure dev secret). Production: required.
JWT_SECRET=

# Vercel production: create a free Redis at https://upstash.com → copy REST URL + token into Vercel env.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: if you use a custom domain (not *.vercel.app), set the exact site origin:
# AUTH_ORIGIN=https://yourdomain.com
