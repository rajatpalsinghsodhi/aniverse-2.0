# Gemini (existing)
GEMINI_API_KEY=

# Auth — no SQL database required. Users/libraries live in process memory (local dev) or optional Upstash Redis (Vercel persistence).
JWT_SECRET=

# Optional — only needed on Vercel if you want signups to survive cold starts (free tier: upstash.com).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: if you use a custom domain (not *.vercel.app), set the exact site origin:
# AUTH_ORIGIN=https://yourdomain.com
